# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nanochat?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Email (Brevo)
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Nanochat"

# App
APP_URL="https://chat.yourdomain.com"

# TURN / STUN (coturn)
TURN_HOST="chat.yourdomain.com"
TURN_PORT=3478
TURN_SECRET="nanochat-turn-secret"
TURN_CREDENTIAL_TTL=86400
# coturn 网络配置（云服务器必填）
# TURN_EXTERNAL_IP: VPS 的公网 IP（客户端能访问的地址）
# TURN_LISTEN_IP:   VPS 的内网 IP（ifconfig/ip addr 看到的地址）
TURN_EXTERNAL_IP="你的公网IP"
TURN_LISTEN_IP="你的内网IP"

# Admin (default password, change after first login)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"
